9-c95f-4729-bbee-209d8d1e14a3", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1127, "y": 0.3527, "width": 0.7801, "height": 0.20599999999999996}, "polygon": [{"x": 0.1127, "y": 0.3527}, {"x": 0.8928, "y": 0.3527}, {"x": 0.8928, "y": 0.5587}, {"x": 0.1127, "y": 0.5587}], "comment": "The focus on personal liberties distracts from evaluating what makes empirical evidence compelling; the student should analyse criteria for scientific reliability rather than political rights.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "0e469138-bb77-4af3-acff-a17aa372efcc", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1127, "y": 0.3527, "width": 0.7801, "height": 0.20599999999999996}, "polygon": [{"x": 0.1127, "y": 0.3527}, {"x": 0.8928, "y": 0.3527}, {"x": 0.8928, "y": 0.5587}, {"x": 0.1127, "y": 0.5587}], "comment": "Mention of Qatar\u00e2\u0080\u0099s political context is promising but lacks concrete examples (e.g. policy texts, public opinion data) to substantiate the claim.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "bebebf2b-8096-469d-bec5-0d0c40d14f0a", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "strength", "pageNumber": 2, "bbox": {"x": 0.1127, "y": 0.5606, "width": 0.7629, "height": 0.33099999999999996}, "polygon": [{"x": 0.1127, "y": 0.5606}, {"x": 0.8756, "y": 0.5606}, {"x": 0.8756, "y": 0.8916}, {"x": 0.1127, "y": 0.8916}], "comment": "Identifying digital knowledge societies introduces a TOK-relevant dimension, recognising how communities establish criteria for good justification.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "bcc54965-225d-499e-af8a-eff308a2b616", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1127, "y": 0.5606, "width": 0.7629, "height": 0.33099999999999996}, "polygon": [{"x": 0.1127, "y": 0.5606}, {"x": 0.8756, "y": 0.5606}, {"x": 0.8756, "y": 0.8916}, {"x": 0.1127, "y": 0.8916}], "comment": "References to evolving WHO evidence remain generic; specifying reports or publications would strengthen the link between evidence and justification.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "ec0fd16a-fd79-4acc-9835-21310abecfe4", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1127, "y": 0.5606, "width": 0.7629, "height": 0.33099999999999996}, "polygon": [{"x": 0.1127, "y": 0.5606}, {"x": 0.8756, "y": 0.5606}, {"x": 0.8756, "y": 0.8916}, {"x": 0.1127, "y": 0.8916}], "comment": "Broad claims about digital societies disregarding evidence need illustration through case studies or data from social media platforms to be convincing.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "cbcae874-b2c6-4d45-ab5e-1f54229e4825", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "strength", "pageNumber": 3, "bbox": {"x": 0.1127, "y": 0.0928, "width": 0.28190000000000004, "height": 0.018000000000000002}, "polygon": [{"x": 0.1127, "y": 0.0928}, {"x": 0.3946, "y": 0.0928}, {"x": 0.3946, "y": 0.1108}, {"x": 0.1127, "y": 0.1108}], "comment": "Object 3\u00e2\u0080\u0099s title situates the diary in a historical context, clearly linking to how personal narratives can serve as evidence in TOK\u00e2\u0080\u0099s historical area of knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "0f525ca6-dea3-4895-a0b6-f1e2ef59c71d", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "strength", "pageNumber": 3, "bbox": {"x": 0.1176, "y": 0.1146, "width": 0.47190000000000004, "height": 0.20830000000000004}, "polygon": [{"x": 0.1176, "y": 0.1146}, {"x": 0.5895, "y": 0.1146}, {"x": 0.5895, "y": 0.3229}, {"x": 0.1176, "y": 0.3229}], "comment": "The photograph of Anne Frank\u00e2\u0080\u0099s diary provides tangible evidence, anchoring the discussion in a primary historical source.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "7ded887a-aeb7-4a98-8e55-abd19bd193f6", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1109, "y": 0.5369, "width": 0.7776, "height": 0.2278}, "polygon": [{"x": 0.1109, "y": 0.5369}, {"x": 0.8885, "y": 0.5369}, {"x": 0.8885, "y": 0.7647}, {"x": 0.1109, "y": 0.7647}], "comment": "Discussion of emotional versus factual aspects is insightful but lacks engagement with TOK concepts like subjective bias versus objective evidence.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "d1ed3fba-a906-4be3-9ec5-bf8d7d4b84ad", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1109, "y": 0.5369, "width": 0.7776, "height": 0.2278}, "polygon": [{"x": 0.1109, "y": 0.5369}, {"x": 0.8885, "y": 0.5369}, {"x": 0.8885, "y": 0.7647}, {"x": 0.1109, "y": 0.7647}], "comment": "Repetition of themes such as \u00e2\u0080\u0098impact on memory\u00e2\u0080\u0099 suggests the need to refine and consolidate ideas to avoid redundancy.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "a779ec26-e982-491b-ad59-d839d7bcbc60", "versionId": "f768619a-f296-4f35-99a0-fd8c6e1900ee", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1109, "y": 0.3277, "width": 0.7776, "height": 0.43700000000000006}, "polygon": [{"x": 0.1109, "y": 0.3277}, {"x": 0.8885, "y": 0.3277}, {"x": 0.8885, "y": 0.7647}, {"x": 0.1109, "y": 0.7647}], "comment": "The justification remains largely theoretical; the student should illustrate how historians critically assess primary sources, enhancing depth and precision.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}]}]}}, "rubricData": {"id": 57, "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "version": 1, "status": "published", "createdAt": "2025-02-20 06:03:43.512632+00", "totalMarks": 10, "description": null, "type": "TOK", "rubricSpecificInfo": null, "tags": [""], "isArchived": false, "gradeBoundaryId": "52ad2701-27bc-42f3-be3f-d63b98d98139", "name": "TOK Exhibition", "slug": "tok-exhibition", "rubricCriteria": [{"id": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "revisionId": 57, "groupName": "TOK Exhibition", "label": null, "orderIndex": 0, "createdAt": "2025-02-20 06:03:55.358727+00", "updatedAt": "2025-07-16 11:21:18.828885+00", "isGradable": true, "showGradedScore": true, "isChecklistCriterion": false, "description": null, "rubricCriterionBands": [{"id": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 0, "marksTo": 0, "orderIndex": 0, "createdAt": "2025-02-20 06:04:46.486581+00", "rubricCriterionStrandBandContents": [{"id": "f7cb0652-0737-403e-8f65-be13bd2fd7f1", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "content": "The exhibition does not reach the standard described by the other levels or does not use one of the IA prompts provided.", "createdAt": "2025-02-20 06:04:58.577216+00"}]}, {"id": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 1, "marksTo": 2, "orderIndex": 1, "createdAt": "2025-02-20 06:04:47.076074+00", "rubricCriterionStrandBandContents": [{"id": "861f06ce-2b51-46ce-a6ee-3022e7080288", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "content": "The exhibition presents\nthree objects, but the\nreal-world contexts of\nthese objects are not\nstated, or the images\npresented may be\nhighly generic images of\ntypes of object rather\nthan of specific\nreal-world objects. Links\nbetween the objects\nand the selected IA\nprompt are made, but\nthese are minimal,\ntenuous, or it is not\nclear what the student is\ntrying to convey.\nThere is very little\njustification offered for\nthe inclusion of each\nobject in the exhibition.\nThe commentary on the\nobjects is highly\ndescriptive or consists\nonly of unsupported\nassertions.", "createdAt": "2025-02-20 06:05:04.443183+00"}]}, {"id": "d33f3613-07e3-4130-984c-f84b6431e3e4", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 3, "marksTo": 4, "orderIndex": 2, "createdAt": "2025-02-20 06:04:48.072006+00", "rubricCriterionStrandBandContents": [{"id": "e8acd337-a77d-4319-a744-06094151d57b", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "d33f3613-07e3-4130-984c-f84b6431e3e4", "content": "The exhibition identifies three objects, although the real-world contexts of the objects may be implied rather than explicitly stated. Basic links between the objects and the selected IA prompt are made, but the explanation of these links is unconvincing and/or unfocused. There is a superficial justification for the inclusion of each object in the exhibition. Reasons for the inclusion of the objects are offered, but these are not supported by appropriate evidence and/or lack relevance to the selected IA prompt. There may be significant repetition across the justifications of the different objects", "createdAt": "2025-02-20 06:05:20.428881+00"}]}, {"id": "bd39c308-b52c-4662-b0f5-64d285be9e95", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 5, "marksTo": 6, "orderIndex": 3, "createdAt": "2025-02-20 06:04:48.868343+00", "rubricCriterionStrandBandContents": [{"id": "c257e18a-e3b8-46f4-b3b9-d9ea5cd5db84", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "bd39c308-b52c-4662-b0f5-64d285be9e95", "content": "The exhibition identifies three objects, although the real-world contexts of these objects may be vaguely or imprecisely stated. There is some explanation of the links between the three objects and the selected IA prompt. There is some justification for the inclusion of each object in the exhibition. Some of the points are supported by evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:31.312862+00"}]}, {"id": "48708361-8824-4c01-bcbd-39c3e493de8e", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 7, "marksTo": 8, "orderIndex": 4, "createdAt": "2025-02-20 06:04:49.555746+00", "rubricCriterionStrandBandContents": [{"id": "f16fe76e-abd8-4dc1-9a4f-50ab9e121c99", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "48708361-8824-4c01-bcbd-39c3e493de8e", "content": "The exhibition identifies three objects and their real-world contexts. Links between each of the three objects and the selected IA prompt are explained, although this explanation may lack precision and clarity in parts. There is a justification of the contribution that each individual object makes to the exhibition. Many of the points are supported by appropriate evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:40.123527+00"}]}, {"id": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 9, "marksTo": 10, "orderIndex": 5, "createdAt": "2025-02-20 06:04:50.346899+00", "rubricCriterionStrandBandContents": [{"id": "055fe2ad-3ef1-4074-af44-83cc3440cc7a", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "content": "The exhibition clearly identifies three objects and their specific real-world contexts. Links between each of the three objects and the selected IA prompt are clearly made and well-explained. There is a strong justification of the particular contribution that each individual object makes to the exhibition. All, or nearly all, of the points are well-supported by appropriate evidence and explicit references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:51.46084+00"}]}], "rubricCriterionStrands": [{"id": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "orderIndex": 0, "createdAt": "2025-02-20 06:03:59.452498+00", "name": "Does the exhibition successfully show how TOK manifests in the world around us?"}]}]}, "similarExemplars": [{"id": "ccaae5ff-e8ef-4594-acb5-285655747726", "title": "What counts as good evidence for a claim?", "description": "", "tags": ["grade-A", "tok", "sl", "reverse-graded"], "slug": "what-counts-as-good-evidence-for-a-claim-9teufj", "isPublic": true, "isPremium": true, "showScores": true, "createdAt": "2026-02-13T08:03:15.785Z", "userSubmissionId": "a92882cb-b3b4-4942-96c6-ed2599666d19", "submissionId": "15a01abe-c8ab-4ade-a9ae-a516c5311844", "similarity": 0.46418596999999995, "normalizedScore": 1, "compositeScore": 0.6249301789999999, "matchingFileId": "", "matchingChunkId": "", "matchingChunkNumber": 0, "userSubmission": {"id": "a92882cb-b3b4-4942-96c6-ed2599666d19", "score": "A", "scoreType": "letter", "level": null, "researchQuestion": null, "tokPrompt": "What counts as good evidence for a claim?", "