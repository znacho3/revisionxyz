8-b553-4fb4a08fecd1", "criterionId": null, "strandId": null, "type": "strength", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.0686, "width": 0.5892999999999999, "height": 0.018200000000000008}, "polygon": [{"x": 0.1145, "y": 0.0686}, {"x": 0.7038, "y": 0.0686}, {"x": 0.7038, "y": 0.0868}, {"x": 0.1145, "y": 0.0868}], "comment": "The prompt is stated clearly at the outset, anchoring the exhibition effectively in the TOK question and guiding the subsequent object analyses with purposeful focus.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "2c21e300-455d-4717-ba65-40eda1273425", "versionId": "23f4d779-1b16-44b8-b553-4fb4a08fecd1", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.117, "y": 0.5757, "width": 0.7578, "height": 0.1411}, "polygon": [{"x": 0.117, "y": 0.5757}, {"x": 0.8748, "y": 0.5757}, {"x": 0.8748, "y": 0.7168}, {"x": 0.117, "y": 0.7168}], "comment": "The narrative about friends\u00e2\u0080\u0099 confusion is engaging but lacks explicit TOK terminology; explicitly tie this anecdote back to the prompt\u00e2\u0080\u0099s knowledge\u00e2\u0080\u0093culture relationship.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "537d43d7-ebb4-4682-b9bd-77797cf42972", "versionId": "23f4d779-1b16-44b8-b553-4fb4a08fecd1", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.117, "y": 0.7467, "width": 0.7717, "height": 0.16510000000000002}, "polygon": [{"x": 0.117, "y": 0.7467}, {"x": 0.8887, "y": 0.7467}, {"x": 0.8887, "y": 0.9118}, {"x": 0.117, "y": 0.9118}], "comment": "The folklore source \u00e2\u0080\u009cThe Swedish Tomte \u00e2\u0080\u0093 Swedish Press\u00e2\u0080\u009d is cited twice without analysis of its credibility; evaluate source reliability to strengthen your justification.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "f3ec95d2-8660-4d15-87f1-cfb6653c2136", "versionId": "23f4d779-1b16-44b8-b553-4fb4a08fecd1", "criterionId": null, "strandId": null, "type": "strength", "pageNumber": 6, "bbox": {"x": 0.1145, "y": 0.0948, "width": 0.7754, "height": 0.2369}, "polygon": [{"x": 0.1145, "y": 0.0948}, {"x": 0.8899, "y": 0.0948}, {"x": 0.8899, "y": 0.3317}, {"x": 0.1145, "y": 0.3317}], "comment": "The analysis of power dynamics in suppression of knowledge insightfully links TOK concepts of value and authority to cultural biases.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}, {"id": "04386177-625b-40c4-832a-2957bc9d9672", "versionId": "23f4d779-1b16-44b8-b553-4fb4a08fecd1", "criterionId": null, "strandId": null, "type": "weakness", "pageNumber": 7, "bbox": {"x": 0.1767, "y": 0.8188, "width": 0.6950000000000001, "height": 0.019100000000000006}, "polygon": [{"x": 0.1767, "y": 0.8188}, {"x": 0.8717, "y": 0.8188}, {"x": 0.8717, "y": 0.8379}, {"x": 0.1767, "y": 0.8379}], "comment": "The Prof. Joe Cain URL appears malformed; verify each link for accessibility and completeness in the final reference list.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": null}]}]}}, "rubricData": {"id": 57, "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "version": 1, "status": "published", "createdAt": "2025-02-20 06:03:43.512632+00", "totalMarks": 10, "description": null, "type": "TOK", "rubricSpecificInfo": null, "tags": [""], "isArchived": false, "gradeBoundaryId": "52ad2701-27bc-42f3-be3f-d63b98d98139", "name": "TOK Exhibition", "slug": "tok-exhibition", "rubricCriteria": [{"id": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "revisionId": 57, "groupName": "TOK Exhibition", "label": null, "orderIndex": 0, "createdAt": "2025-02-20 06:03:55.358727+00", "updatedAt": "2025-07-16 11:21:18.828885+00", "isGradable": true, "showGradedScore": true, "isChecklistCriterion": false, "description": null, "rubricCriterionBands": [{"id": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 0, "marksTo": 0, "orderIndex": 0, "createdAt": "2025-02-20 06:04:46.486581+00", "rubricCriterionStrandBandContents": [{"id": "f7cb0652-0737-403e-8f65-be13bd2fd7f1", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "content": "The exhibition does not reach the standard described by the other levels or does not use one of the IA prompts provided.", "createdAt": "2025-02-20 06:04:58.577216+00"}]}, {"id": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 1, "marksTo": 2, "orderIndex": 1, "createdAt": "2025-02-20 06:04:47.076074+00", "rubricCriterionStrandBandContents": [{"id": "861f06ce-2b51-46ce-a6ee-3022e7080288", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "content": "The exhibition presents\nthree objects, but the\nreal-world contexts of\nthese objects are not\nstated, or the images\npresented may be\nhighly generic images of\ntypes of object rather\nthan of specific\nreal-world objects. Links\nbetween the objects\nand the selected IA\nprompt are made, but\nthese are minimal,\ntenuous, or it is not\nclear what the student is\ntrying to convey.\nThere is very little\njustification offered for\nthe inclusion of each\nobject in the exhibition.\nThe commentary on the\nobjects is highly\ndescriptive or consists\nonly of unsupported\nassertions.", "createdAt": "2025-02-20 06:05:04.443183+00"}]}, {"id": "d33f3613-07e3-4130-984c-f84b6431e3e4", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 3, "marksTo": 4, "orderIndex": 2, "createdAt": "2025-02-20 06:04:48.072006+00", "rubricCriterionStrandBandContents": [{"id": "e8acd337-a77d-4319-a744-06094151d57b", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "d33f3613-07e3-4130-984c-f84b6431e3e4", "content": "The exhibition identifies three objects, although the real-world contexts of the objects may be implied rather than explicitly stated. Basic links between the objects and the selected IA prompt are made, but the explanation of these links is unconvincing and/or unfocused. There is a superficial justification for the inclusion of each object in the exhibition. Reasons for the inclusion of the objects are offered, but these are not supported by appropriate evidence and/or lack relevance to the selected IA prompt. There may be significant repetition across the justifications of the different objects", "createdAt": "2025-02-20 06:05:20.428881+00"}]}, {"id": "bd39c308-b52c-4662-b0f5-64d285be9e95", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 5, "marksTo": 6, "orderIndex": 3, "createdAt": "2025-02-20 06:04:48.868343+00", "rubricCriterionStrandBandContents": [{"id": "c257e18a-e3b8-46f4-b3b9-d9ea5cd5db84", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "bd39c308-b52c-4662-b0f5-64d285be9e95", "content": "The exhibition identifies three objects, although the real-world contexts of these objects may be vaguely or imprecisely stated. There is some explanation of the links between the three objects and the selected IA prompt. There is some justification for the inclusion of each object in the exhibition. Some of the points are supported by evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:31.312862+00"}]}, {"id": "48708361-8824-4c01-bcbd-39c3e493de8e", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 7, "marksTo": 8, "orderIndex": 4, "createdAt": "2025-02-20 06:04:49.555746+00", "rubricCriterionStrandBandContents": [{"id": "f16fe76e-abd8-4dc1-9a4f-50ab9e121c99", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "48708361-8824-4c01-bcbd-39c3e493de8e", "content": "The exhibition identifies three objects and their real-world contexts. Links between each of the three objects and the selected IA prompt are explained, although this explanation may lack precision and clarity in parts. There is a justification of the contribution that each individual object makes to the exhibition. Many of the points are supported by appropriate evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:40.123527+00"}]}, {"id": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 9, "marksTo": 10, "orderIndex": 5, "createdAt": "2025-02-20 06:04:50.346899+00", "rubricCriterionStrandBandContents": [{"id": "055fe2ad-3ef1-4074-af44-83cc3440cc7a", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "content": "The exhibition clearly identifies three objects and their specific real-world contexts. Links between each of the three objects and the selected IA prompt are clearly made and well-explained. There is a strong justification of the particular contribution that each individual object makes to the exhibition. All, or nearly all, of the points are well-supported by appropriate evidence and explicit references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:51.46084+00"}]}], "rubricCriterionStrands": [{"id": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "orderIndex": 0, "createdAt": "2025-02-20 06:03:59.452498+00", "name": "Does the exhibition successfully show how TOK manifests in the world around us?"}]}]}, "similarExemplars": [{"id": "e6fb36b5-ceb4-42d6-8b1b-c2d8f223ae1b", "title": "What is the relationship between knowledge and culture?", "description": "", "tags"