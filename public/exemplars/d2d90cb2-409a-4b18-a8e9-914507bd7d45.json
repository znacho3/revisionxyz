tions": false, "enableVideos": false, "enableGlossary": true, "enableNotes": true, "enableFlashcards": false, "enableLessons": false, "enableExemplars": true, "enableTextbook": true, "enableCourseworkGuide": false, "questionCount": 0, "videoCount": 18, "lessonCount": 66, "noteCount": 68, "flashcardDeckCount": 87, "cheatsheetCount": 0, "vocabularyPracticeCount": 0, "caseStudyCount": 0, "descendantTopicCount": 68, "examDate": null, "showAuthoring": true, "vocabRushExclusive": false}, "rubric": {"id": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "userId": "ad5a804b-62aa-46ae-bb6f-6c002e645444", "name": "TOK Exhibition", "slug": "tok-exhibition", "createdAt": "2025-02-20 06:03:43.512632+00", "updatedAt": "2025-07-22 09:37:44.53073+00", "currentRevisionId": 57}, "isPremium": true, "versions": [{"id": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "submissionId": "6202b51b-d95e-4946-bbe2-9395759bda7e", "versionNumber": 1, "status": "COMPLETED", "step": "FINALIZING_SCORE", "finishReason": "stop", "error": null, "isRelevant": true, "createdAt": "2026-02-13T08:13:13.132Z", "completedAt": "2026-02-13T08:17:11.353Z", "expiresAt": "2026-02-15T08:13:13.132Z", "files": [{"id": "cb64792b-6629-4869-9c56-c5d20091a8d5", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "fileUrl": "https://grader-public.revisiondojo.com/exemplars/27e0e8d8-3570-44d6-9e01-68d78cccdf1e.application/pdf", "fileName": "Coursework_Exemplar.application/pdf", "fileType": "application/pdf", "pageCount": 5, "uploadedAt": "2026-02-13T08:13:17.293Z", "expiresAt": "2026-02-15T08:13:13.132Z"}], "feedback": [{"versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "score": 5, "strengths": ["Clear identification of three distinctive objects and their specific real-world or digital contexts", "Explicit attempts to link object features (e.g., chopstick technique, Qipao symbolism, Terracotta Army craftsmanship) to the IA prompt", "Use of sources and illustrative detail to support many of the object justifications"], "weaknesses": ["Analysis remains largely descriptive and personal, with limited engagement with core TOK concepts (ways of knowing, shared vs personal knowledge, knowledge claims)", "Links to the prompt are often asserted rather than fully developed and occasionally repetitive across objects", "Choice of a fictional character as an object is creative but insufficiently justified, weakening overall coherence"], "calculationMethod": "Holistic AI evaluation: The student\u00e2\u0080\u0099s exhibition meets the descriptors for the 5\u00e2\u0080\u00936 band: three objects are clearly identified with their contexts, and basic explanations of links to the prompt are offered. There is emerging awareness of how cultural practices transmit knowledge, supported by sources and illustrative details. However, the work lacks the analytical depth, precision, and critical evaluation required for higher bands. Engagement with TOK terminology and concepts is minimal, object-to-prompt connections are sometimes undeveloped or repetitive, and the fictional object is under-analysed. A final score of 5 accurately reflects this uneven but adequate performance.", "groupName": "TOK Exhibition"}], "strandSelections": [{"versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "strandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "selectedBandId": "bd39c308-b52c-4662-b0f5-64d285be9e95", "bandScore": 5, "reasoning": "$49"}], "annotations": [{"id": "bd6ff72e-7fca-41dd-92ae-2264706f3253", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.102, "width": 0.49810000000000004, "height": 0.01780000000000001}, "polygon": [{"x": 0.1145, "y": 0.102}, {"x": 0.6126, "y": 0.102}, {"x": 0.6126, "y": 0.1198}, {"x": 0.1145, "y": 0.1198}], "comment": "The student restates the IA prompt but does not formulate an explicit knowledge question or thesis to guide the analysis. Defining a clear knowledge question would anchor the exhibition and focus subsequent object discussions.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "74ac170f-0e99-4ce8-9599-adc84bf4d882", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "strength", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.7097, "width": 0.7709999999999999, "height": 0.19010000000000005}, "polygon": [{"x": 0.1145, "y": 0.7097}, {"x": 0.8855, "y": 0.7097}, {"x": 0.8855, "y": 0.8998}, {"x": 0.1145, "y": 0.8998}], "comment": "Strong identification of procedural knowledge involved in using chopsticks. To build on this, reference TOK concepts like tacit versus explicit knowledge to discuss how this skill is learned and transmitted.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "e09b092b-b1a4-42a3-8e7c-05970cab1376", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "strength", "pageNumber": 1, "bbox": {"x": 0.2704, "y": 0.175, "width": 0.44910000000000005, "height": 0.313}, "polygon": [{"x": 0.2704, "y": 0.175}, {"x": 0.7195, "y": 0.175}, {"x": 0.7195, "y": 0.488}, {"x": 0.2704, "y": 0.488}], "comment": "The image description is detailed, but you could link visual motifs (square, circular patterns) to their symbolic significance, illustrating how such imagery conveys cultural knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "eb65680b-08db-45d5-995a-6c6549fec2b6", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.7097, "width": 0.7709999999999999, "height": 0.19010000000000005}, "polygon": [{"x": 0.1145, "y": 0.7097}, {"x": 0.8855, "y": 0.7097}, {"x": 0.8855, "y": 0.8998}, {"x": 0.1145, "y": 0.8998}], "comment": "The sentence concluding this paragraph is cut off, creating ambiguity. Ensure that each thought is fully expressed to maintain clarity and coherence.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "9611f5b2-8264-4b75-9bec-45e51f995cf4", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1145, "y": 0.0868, "width": 0.7728999999999999, "height": 0.1421}, "polygon": [{"x": 0.1145, "y": 0.0868}, {"x": 0.8874, "y": 0.0868}, {"x": 0.8874, "y": 0.2289}, {"x": 0.1145, "y": 0.2289}], "comment": "The personal reflection on identity is engaging but lacks analytical depth. Link this feeling of belonging to shared knowledge practices within the Chinese community through TOK frameworks.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "2c61b1af-f1a4-40f3-9d6a-49b7bcdfcf9f", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1145, "y": 0.3188, "width": 0.7622, "height": 0.09390000000000004}, "polygon": [{"x": 0.1145, "y": 0.3188}, {"x": 0.8767, "y": 0.3188}, {"x": 0.8767, "y": 0.4127}, {"x": 0.1145, "y": 0.4127}], "comment": "Repetition of linking statements without new insights weakens justification. Delve into how the Qipao fosters or challenges cultural knowledge transmission rather than reiterating the link.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "b3ebd982-349a-4af0-aa06-b2bae4caabf3", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "strength", "pageNumber": 3, "bbox": {"x": 0.2535, "y": 0.4328, "width": 0.4823, "height": 0.22300000000000003}, "polygon": [{"x": 0.2535, "y": 0.4328}, {"x": 0.7358, "y": 0.4328}, {"x": 0.7358, "y": 0.6558}, {"x": 0.2535, "y": 0.6558}], "comment": "The historical photograph of the Terracotta Army provides strong contextual grounding. To elevate your analysis, consider how photographic perspective shapes our knowledge of these artifacts.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "a7b23828-1fbc-4453-b112-4bd969fbc395", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.117, "y": 0.2498, "width": 0.7736, "height": 0.04090000000000002}, "polygon": [{"x": 0.117, "y": 0.2498}, {"x": 0.8906, "y": 0.2498}, {"x": 0.8906, "y": 0.2907}, {"x": 0.117, "y": 0.2907}], "comment": "Assertion of a link to the IA prompt without development. You should explain specifically how chopstick use embodies the interaction between cultural tradition and knowledge acquisition.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "7ceaaa3b-7d8e-4adc-b4cc-6a578c732250", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1145, "y": 0.6986, "width": 0.7704, "height": 0.21499999999999997}, "polygon": [{"x": 0.1145, "y": 0.6986}, {"x": 0.8849, "y": 0.6986}, {"x": 0.8849, "y": 0.9136}, {"x": 0.1145, "y": 0.9136}], "comment": "The description of Musa\u00e2\u0080\u0099s costume is vivid but remains descriptive. Analyze how media representations like these influence viewers\u00e2\u0080\u0099 understanding of cultural knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "79ab598e-7425-4aad-b45e-8a3e700cfe12", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1145, "y": 0.6986, "width": 0.7704, "height": 0.21499999999999997}, "polygon": [{"x": 0.1145, "y": 0.6986}, {"x": 0.8849, "y": 0.6986}, {"x": 0.8849, "y": 0.9136}, {"x": 0.1145, "y": 0.9136}], "comment": "The claim that Musa\u00e2\u0080\u0099s appearance was inspired by Lucy Liu lacks citation. Provide evidence or academic sources to support this connection.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "f7feddfb-3fe2-434e-a345-e5549dd345b5", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.5499, "width": 0.7641, "height": 0.13979999999999992}, "polygon": [{"x": 0.1145, "y": 0.5499}, {"x": 0.8786, "y": 0.5499}, {"x": 0.8786, "y": 0.6897}, {"x": 0.1145, "y": 0.6897}], "comment": "This description of the chopsticks\u00e2\u0080\u0099 cultural role is thorough yet remains mainly descriptive. To deepen analysis, the student should examine how these symbols function as shared knowledge within the community.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "54b3d996-3c7a-4844-ab4b-7dfea785c7fa", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "general", "pageNumber": 2, "bbox": {"x": 0.4075, "y": 0.3117, "width": 0.1743, "height": 0.32720000000000005}, "polygon": [{"x": 0.4075, "y": 0.3117}, {"x": 0.5818, "y": 0.3117}, {"x": 0.5818, "y": 0.6389}, {"x": 0.4075, "y": 0.6389}], "comment": "Choosing a fictional character as an object is creative, but provide a stronger justification by showing how fiction serves as a medium for transmitting cultural knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "34724334-35a7-4418-9ffb-3b7cb7f0a904", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1145, "y": 0.0846, "width": 0.7691, "height": 0.21499999999999997}, "polygon": [{"x": 0.1145, "y": 0.0846}, {"x": 0.8836, "y": 0.0846}, {"x": 0.8836, "y": 0.2996}, {"x": 0.1145, "y": 0.2996}], "comment": "Discussion of other characters (e.g., Flora) drifts from the central object focus. Refine the analysis to concentrate solely on the exhibition object and its relevance to the prompt.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "463de77c-5e66-444e-b0fe-a786cc657ebf", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1145, "y": 0.7057, "width": 0.7522, "height": 0.19010000000000005}, "polygon": [{"x": 0.1145, "y": 0.7057}, {"x": 0.8667, "y": 0.7057}, {"x": 0.8667, "y": 0.8958}, {"x": 0.1145, "y": 0.8958}], "comment": "Technical details on sculpture size and rank are informative but descriptive. Analyze how these hierarchies reflect societal knowledge structures and cultural values in Qin China.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "0ced990f-ab4d-4fdf-8c6c-28124aecffb2", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 4, "bbox": {"x": 0.1145, "y": 0.0868, "width": 0.7641, "height": 0.09219999999999999}, "polygon": [{"x": 0.1145, "y": 0.0868}, {"x": 0.8786, "y": 0.0868}, {"x": 0.8786, "y": 0.179}, {"x": 0.1145, "y": 0.179}], "comment": "Reflection on heritage pride is meaningful but repetitive of earlier identity themes. Introduce comparative analysis that contrasts individual and collective aspects of cultural knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "9a34fd45-6c54-432a-9ad7-f13f72ac37e0", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 5, "bbox": {"x": 0.1145, "y": 0.8749, "width": 0.09119999999999999, "height": 0.016900000000000026}, "polygon": [{"x": 0.1145, "y": 0.8749}, {"x": 0.2057, "y": 0.8749}, {"x": 0.2057, "y": 0.8918}, {"x": 0.1145, "y": 0.8918}], "comment": "Listing Chat-GPT as an information source is inappropriate for TOK evidence. The student should replace AI-generated content with verifiable academic or primary sources.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "a5db98f5-0ea2-4459-ab58-f6e1445a5ec9", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "strength", "pageNumber": 4, "bbox": {"x": 0.1145, "y": 0.1999, "width": 0.7709999999999999, "height": 0.1888}, "polygon": [{"x": 0.1145, "y": 0.1999}, {"x": 0.8855, "y": 0.1999}, {"x": 0.8855, "y": 0.3887}, {"x": 0.1145, "y": 0.3887}], "comment": "Insightful identification of craftsmanship knowledge. To deepen, discuss ways of knowing (e.g., sense perception, imagination) involved in sculptural techniques.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "68056b3a-cbce-42a6-b06c-ec542e89ff9c", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 4, "bbox": {"x": 0.1145, "y": 0.4087, "width": 0.7522, "height": 0.0922}, "polygon": [{"x": 0.1145, "y": 0.4087}, {"x": 0.8667, "y": 0.4087}, {"x": 0.8667, "y": 0.5009}, {"x": 0.1145, "y": 0.5009}], "comment": "The conclusion repeats the prompt without synthesizing across objects. Craft a synthesis that compares how each object uniquely illustrates the interplay of knowledge and culture.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "c3ed195f-672f-44ee-a028-1cf2573a0e7d", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 1, "bbox": {"x": 0.1145, "y": 0.5499, "width": 0.7641, "height": 0.13979999999999992}, "polygon": [{"x": 0.1145, "y": 0.5499}, {"x": 0.8786, "y": 0.5499}, {"x": 0.8786, "y": 0.6897}, {"x": 0.1145, "y": 0.6897}], "comment": "There is no introductory explanation of why these three objects were chosen as a cohesive set. A brief overview of their collective significance would improve coherence.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "f7706942-61fd-421a-9007-cbe547525e7a", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 2, "bbox": {"x": 0.1145, "y": 0.6986, "width": 0.7704, "height": 0.21499999999999997}, "polygon": [{"x": 0.1145, "y": 0.6986}, {"x": 0.8849, "y": 0.6986}, {"x": 0.8849, "y": 0.9136}, {"x": 0.1145, "y": 0.9136}], "comment": "The end-of-object reflection drifts into broad cultural appreciation without critically examining how fiction mediates knowledge. Focus on specific knowledge claims embodied by the Qipao design.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "f30526e4-3126-41e0-86a3-78e2ec40bbd2", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 3, "bbox": {"x": 0.1145, "y": 0.7057, "width": 0.7522, "height": 0.19010000000000005}, "polygon": [{"x": 0.1145, "y": 0.7057}, {"x": 0.8667, "y": 0.7057}, {"x": 0.8667, "y": 0.8958}, {"x": 0.1145, "y": 0.8958}], "comment": "The closing of the Terracotta discussion restates earlier points. Strengthen the ending by evaluating the implications of preserving traditional craftsmanship for future cultural knowledge.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "3ff1d10a-cd4d-47ed-b27e-1b3f2dd57bc6", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 5, "bbox": {"x": 0.4296, "y": 0.0886, "width": 0.13329999999999997, "height": 0.019100000000000006}, "polygon": [{"x": 0.4296, "y": 0.0886}, {"x": 0.5629, "y": 0.0886}, {"x": 0.5629, "y": 0.1077}, {"x": 0.4296, "y": 0.1077}], "comment": "The Works Cited section relies heavily on popular and user-generated sources. Incorporating peer-reviewed or primary academic materials would enhance the exhibition\u00e2\u0080\u0099s evidential rigor.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}, {"id": "0fda3c41-3307-46f9-83c5-52f633cd79c4", "versionId": "1b36ad00-3d61-4338-a9fe-2d827bb2eddd", "criterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "strandId": null, "type": "weakness", "pageNumber": 5, "bbox": {"x": 0.1145, "y": 0.3526, "width": 0.7709999999999999, "height": 0.035199999999999954}, "polygon": [{"x": 0.1145, "y": 0.3526}, {"x": 0.8855, "y": 0.3526}, {"x": 0.8855, "y": 0.3878}, {"x": 0.1145, "y": 0.3878}], "comment": "Sources such as Pinterest and Study.com vary in reliability. Critically evaluate each reference\u00e2\u0080\u0099s credibility and consider more authoritative scholarly publications.", "color": null, "status": "unread", "statusUpdatedAt": null, "statusUpdatedBy": null, "groupName": "TOK Exhibition"}]}]}}, "rubricData": {"id": 57, "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "version": 1, "status": "published", "createdAt": "2025-02-20 06:03:43.512632+00", "totalMarks": 10, "description": null, "type": "TOK", "rubricSpecificInfo": null, "tags": [""], "isArchived": false, "gradeBoundaryId": "52ad2701-27bc-42f3-be3f-d63b98d98139", "name": "TOK Exhibition", "slug": "tok-exhibition", "rubricCriteria": [{"id": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", "revisionId": 57, "groupName": "TOK Exhibition", "label": null, "orderIndex": 0, "createdAt": "2025-02-20 06:03:55.358727+00", "updatedAt": "2025-07-16 11:21:18.828885+00", "isGradable": true, "showGradedScore": true, "isChecklistCriterion": false, "description": null, "rubricCriterionBands": [{"id": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 0, "marksTo": 0, "orderIndex": 0, "createdAt": "2025-02-20 06:04:46.486581+00", "rubricCriterionStrandBandContents": [{"id": "f7cb0652-0737-403e-8f65-be13bd2fd7f1", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "9ff6a42c-458d-4ba2-aed7-d0ce052fc68b", "content": "The exhibition does not reach the standard described by the other levels or does not use one of the IA prompts provided.", "createdAt": "2025-02-20 06:04:58.577216+00"}]}, {"id": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 1, "marksTo": 2, "orderIndex": 1, "createdAt": "2025-02-20 06:04:47.076074+00", "rubricCriterionStrandBandContents": [{"id": "861f06ce-2b51-46ce-a6ee-3022e7080288", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "a1ba39dd-f4e1-46d0-92fb-f804616659df", "content": "The exhibition presents\nthree objects, but the\nreal-world contexts of\nthese objects are not\nstated, or the images\npresented may be\nhighly generic images of\ntypes of object rather\nthan of specific\nreal-world objects. Links\nbetween the objects\nand the selected IA\nprompt are made, but\nthese are minimal,\ntenuous, or it is not\nclear what the student is\ntrying to convey.\nThere is very little\njustification offered for\nthe inclusion of each\nobject in the exhibition.\nThe commentary on the\nobjects is highly\ndescriptive or consists\nonly of unsupported\nassertions.", "createdAt": "2025-02-20 06:05:04.443183+00"}]}, {"id": "d33f3613-07e3-4130-984c-f84b6431e3e4", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 3, "marksTo": 4, "orderIndex": 2, "createdAt": "2025-02-20 06:04:48.072006+00", "rubricCriterionStrandBandContents": [{"id": "e8acd337-a77d-4319-a744-06094151d57b", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "d33f3613-07e3-4130-984c-f84b6431e3e4", "content": "The exhibition identifies three objects, although the real-world contexts of the objects may be implied rather than explicitly stated. Basic links between the objects and the selected IA prompt are made, but the explanation of these links is unconvincing and/or unfocused. There is a superficial justification for the inclusion of each object in the exhibition. Reasons for the inclusion of the objects are offered, but these are not supported by appropriate evidence and/or lack relevance to the selected IA prompt. There may be significant repetition across the justifications of the different objects", "createdAt": "2025-02-20 06:05:20.428881+00"}]}, {"id": "bd39c308-b52c-4662-b0f5-64d285be9e95", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 5, "marksTo": 6, "orderIndex": 3, "createdAt": "2025-02-20 06:04:48.868343+00", "rubricCriterionStrandBandContents": [{"id": "c257e18a-e3b8-46f4-b3b9-d9ea5cd5db84", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "bd39c308-b52c-4662-b0f5-64d285be9e95", "content": "The exhibition identifies three objects, although the real-world contexts of these objects may be vaguely or imprecisely stated. There is some explanation of the links between the three objects and the selected IA prompt. There is some justification for the inclusion of each object in the exhibition. Some of the points are supported by evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:31.312862+00"}]}, {"id": "48708361-8824-4c01-bcbd-39c3e493de8e", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 7, "marksTo": 8, "orderIndex": 4, "createdAt": "2025-02-20 06:04:49.555746+00", "rubricCriterionStrandBandContents": [{"id": "f16fe76e-abd8-4dc1-9a4f-50ab9e121c99", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "48708361-8824-4c01-bcbd-39c3e493de8e", "content": "The exhibition identifies three objects and their real-world contexts. Links between each of the three objects and the selected IA prompt are explained, although this explanation may lack precision and clarity in parts. There is a justification of the contribution that each individual object makes to the exhibition. Many of the points are supported by appropriate evidence and references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:40.123527+00"}]}, {"id": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "marksFrom": 9, "marksTo": 10, "orderIndex": 5, "createdAt": "2025-02-20 06:04:50.346899+00", "rubricCriterionStrandBandContents": [{"id": "055fe2ad-3ef1-4074-af44-83cc3440cc7a", "rubricCriterionStrandId": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionBandId": "5552e9fd-0d0a-4bb2-9ece-5e7a3c438771", "content": "The exhibition clearly identifies three objects and their specific real-world contexts. Links between each of the three objects and the selected IA prompt are clearly made and well-explained. There is a strong justification of the particular contribution that each individual object makes to the exhibition. All, or nearly all, of the points are well-supported by appropriate evidence and explicit references to the selected IA prompt.", "createdAt": "2025-02-20 06:05:51.46084+00"}]}], "rubricCriterionStrands": [{"id": "17a30166-bc52-427b-904b-44efbdd5c7d7", "rubricCriterionId": "cc70033e-f75e-42d2-8670-9501aa0d86a1", "orderIndex": 0, "createdAt": "2025-02-20 06:03:59.452498+00", "name": "Does the exhibition successfully show how TOK manifests in the world around us?"}]}]}, "similarExemplars": [{"id": "b909cb8e-c603-45c3-9acb-77e0c4c16b2e", "title": "21. What is the relationship between knowledge and culture?", "description": "", "tags": ["grade-B", "tok", "sl"], "slug": "21-what-is-the-relationship-between-knowledge-and-culture", "isPublic": true, "isPremium": true, "showScores": true, "createdAt": "2025-08-05T07:30:18.176Z", "userSubmissionId": "870aa5ab-c28d-4254-a02b-b6815cfea511", "submissionId": "ad57293a-d9db-41cf-bd0a-b5210d4cec07", "similarity": 0.4991608329999999, "normalizedScore": 0.8, "compositeScore": 0.5894125830999999, "matchingFileId": "", "matchingChunkId": "", "matchingChunkNumber": 0, "userSubmission": {"id": "870aa5ab-c28d-4254-a02b-b6815cfea511", "score": "B", "scoreType": "letter", "level": null, "researchQuestion": null, "tokPrompt": null, "title": "21. What is the relationship between knowledge and culture?", "cohort": "M25", "createdAt": "2025-07-16T03:54:56.724Z", "subjectId": 582, "rubricId": "15a001d0-4b6b-41b6-abae-4e9498385eaf", 