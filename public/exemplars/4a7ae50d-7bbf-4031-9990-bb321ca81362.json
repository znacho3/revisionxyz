dContents": [{"id": "6732fd65-220a-47e2-9d92-a41bbba55ed3", "rubricCriterionStrandId": "8dc05406-c8b4-4575-8c75-4290cad64660", "rubricCriterionBandId": "3b450ec9-efb1-46cb-aaed-681a0775166b", "content": "The discussion is weakly connected to the title. While there may be links to the areas of knowledge, any relevant points are descriptive or consist only of unsupported assertions.", "createdAt": "2025-02-19 14:07:39.490543+00"}]}, {"id": "d4162f84-b125-401d-a926-d829eb4f30f0", "rubricCriterionId": "e708a9f2-1aa2-48b1-8848-2655ed338b08", "marksFrom": 3, "marksTo": 4, "orderIndex": 2, "createdAt": "2025-02-19 14:07:39.46212+00", "rubricCriterionStrandBandContents": [{"id": "eb22a0ff-4301-4f74-a26a-75df0f97da13", "rubricCriterionStrandId": "8dc05406-c8b4-4575-8c75-4290cad64660", "rubricCriterionBandId": "d4162f84-b125-401d-a926-d829eb4f30f0", "content": "The discussion is connected to the title and makes superficial or limited links to areas of knowledge. The discussion is largely descriptive. Limited arguments are offered but they are unclear and are not supported by effective examples.", "createdAt": "2025-02-19 14:08:01.054427+00"}]}, {"id": "de853dad-e950-480d-9134-8b812d454857", "rubricCriterionId": "e708a9f2-1aa2-48b1-8848-2655ed338b08", "marksFrom": 5, "marksTo": 6, "orderIndex": 3, "createdAt": "2025-02-19 14:08:04.156832+00", "rubricCriterionStrandBandContents": [{"id": "efb2117a-1b34-47d4-92b6-80a42f9a0c52", "rubricCriterionStrandId": "8dc05406-c8b4-4575-8c75-4290cad64660", "rubricCriterionBandId": "de853dad-e950-480d-9134-8b812d454857", "content": "The discussion\nis focused on\nthe title and is\ndeveloped with\nsome links to\nareas of\nknowledge.\nArguments are\noffered and are\nsupported by\nexamples.\nThere is some\nawareness of\ndifferent points\nof view.", "createdAt": "2025-02-19 14:08:10.083+00"}]}, {"id": "1b677f04-01fe-475c-901f-b68689d91135", "rubricCriterionId": "e708a9f2-1aa2-48b1-8848-2655ed338b08", "marksFrom": 7, "marksTo": 8, "orderIndex": 4,