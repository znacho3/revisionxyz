        "id": "147a7bc5-4f5e-4593-9de3-e15bd384b193",
        "specification": "A product designer is conducting a sensory evaluation of different surface finishes for a luxury vehicle's interior. Participants are asked to classify a set of leather samples into distinct groups based on their specific grain pattern (e.g., 'Pebbled', 'Smooth', 'Cross-hatched', 'Perforated'). \n\nWhich type of psychological data scale is being utilized in this classification task?",
        "questionType": "MC",
        "level": "sl",
        "paper": "ib-1",
        "subjectId": 293,
        "difficulty": null,
        "questionSet": "STUDENT",
        "hasVideo": false,
        "hasExplanation": false,
        "metadata": {
          "ramen": {
            "approvedBy": "sentinel-user",
            "workflowId": "ramen-ib-physics-new-147a7bc5-4f5e-4593-9de3-e15bd384b193-1771929956947",
            "generatedAt": "2026-02-25T14:14:58.784Z",
            "sourceRevisionId": 764697
          }
        },
        "currentRevisionId": 1685157,
        "parts": [],
        "options": [
          {
            "id": 4920099,
            "content": "Ordinal",
            "correct": false,
            "order": 0,
            "markscheme": "Ordinal scales involve ranking or ordering (e.g., first, second, third), but do not apply to simple categorization by type."
          },
          {
            "id": 4920100,
            "content": "Ratio",
            "correct": false,
            "order": 1,
            "markscheme": "Ratio scales have a true zero point and allow for comparison of magnitudes (e.g., weight or height), which is not present in qualitative categorization."
          },
          {
            "id": 4920101,
            "content": "Nominal",
            "correct": true,
            "order": 2,
            "markscheme": "Nominal scales are used for labeling variables without any quantitative value or order; they simply categorize data into mutually exclusive groups."
          },
          {
            "id": 4920102,
            "content": "Interval",
            "correct": false,
            "order": 3,
            "markscheme": "Interval scales have known equal distances between points but no true zero (e.g., temperature in Celsius), which does not match categorization by texture type."
          }
        ],
        "examBoardId": 4
